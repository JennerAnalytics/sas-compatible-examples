# Notebook re-execution artifacts (outputs are embedded in the .ipynb itself)
**/listing.txt
**/ods_output/
**/work/
**/.cas/
**/*.spec.json
# PROC BOXPLOT/ANOM default output datasets dropped next to a notebook
**/BOXSTATS
**/LINEHISTORY
# PROC OPTMODEL/CLP/CPM makespan side-file + extension-less resource-load export
translations/*/procs/clp/*/mk
translations/*/procs/cpm/*/mk
translations/*/procs/cpm/*/rprofile
# PROC EFFECTPLOT MEANS OUT= dataset (output out=mn) dropped next to a notebook
translations/*/procs/effectplot/*/mn
# PROC GAGE (via PROC MEANS output out=partavg) dataset dropped next to a notebook
translations/*/procs/gage/*/partavg
# loose plot/data files the kernel drops next to a notebook
translations/**/*.svg
translations/**/*.png
translations/**/*.csv
translations/**/*.csv.meta
translations/**/*.lst
temp/
# stray CLI logs / caches from local runs
/help.log
/help.lst
/run.log
/run.lst
__pycache__/
